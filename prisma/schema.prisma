datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  password          String
  role              String    @default("SISWA")
  
  // Data Profil
  birthDate         DateTime?
  avatar            String?
  
  // Data Magang (Sesuai dengan payload Flutter kamu)
  guru_uid          String?   // Ditambahkan agar sinkron dengan payload
  pkl_place_name    String?   // Sesuai payload
  pkl_place_address String?   // Sesuai payload
  latitude          Float?    @map("pkl_lat") // Mapping ke nama di payload
  longitude         Float?    @map("pkl_lng") // Mapping ke nama di payload
  
  presensi          Presensi[]
  logbooks          Logbook[]
  createdAt         DateTime  @default(now())
}

model Presensi {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  status    String   
  isValid   Boolean  @default(true)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Logbook {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  activity  String   @db.Text
  status    String   @default("PENDING")
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}